{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pixel Angler The Real",
  "version": "0.1.0",
  "identifier": "com.pixelangler.thereal",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm --filter @tra/client-pc build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../client-pc/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pixel Angler: The Real",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
