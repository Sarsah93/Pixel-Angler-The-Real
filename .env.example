# =============================================================
# The Real Angler — Environment Variables Template
# 복사 후 .env 로 저장하고 실제 API 키를 입력하세요
# DO NOT commit .env to git
# =============================================================

# ─────────────────────────────────────────────
# 공공데이터포털 (data.go.kr) API 키
# 발급: https://www.data.go.kr/
# ─────────────────────────────────────────────
PUBLIC_DATA_API_KEY=YOUR_PUBLIC_DATA_API_KEY_HERE

# ─────────────────────────────────────────────
# 기상청 API (기상청 날씨 허브)
# 발급: https://apihub.kma.go.kr/
# ─────────────────────────────────────────────
KMA_API_KEY=YOUR_KMA_API_KEY_HERE

# ─────────────────────────────────────────────
# 국립해양조사원 (조위, 수온, 파고)
# 발급: https://www.khoa.go.kr/oceangrid/khoa/apiService.do
# ─────────────────────────────────────────────
KHOA_API_KEY=YOUR_KHOA_API_KEY_HERE

# ─────────────────────────────────────────────
# 해양수산부 국립해양측위정보원 — 해양기상 정보 (전국 76개 관측소)
# 발급: https://marineweather.nmpnt.go.kr/serviceReq/serviceOpenApiIntro.do
#   ※ 공공데이터포털(15033708)은 LINK 유형이라 위 포털에서 별도 발급받아야 하며
#     키 형식이 UUID다 (data.go.kr의 base64 키와 다름).
#   ※ HTTP 전용(포트 8001) — HTTPS 배포 시 프록시 필요
# ─────────────────────────────────────────────
VITE_NMPNT_API_KEY=YOUR_NMPNT_API_KEY_HERE

# ─────────────────────────────────────────────
# 서버 설정
# ─────────────────────────────────────────────
SERVER_PORT=4000
WS_PORT=4001
NODE_ENV=development

# ─────────────────────────────────────────────
# 클라이언트 설정
# ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4001

# ─────────────────────────────────────────────
# 개발 옵션
# ─────────────────────────────────────────────
# true = Mock 데이터 사용 (API 키 없이 개발 가능)
VITE_USE_MOCK_DATA=true
USE_MOCK_DATA=true
